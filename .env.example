# ===========================================
# mousecake-go 开发环境变量模板
# 复制为 .env 并填入实际值：cp .env.example .env
# ===========================================

# ---------- 数据库 ----------
MOUSECAKE_DATABASE_HOST=localhost
MOUSECAKE_DATABASE_USER=mouse_user
MOUSECAKE_DATABASE_PASSWORD=dev_password_123

# ---------- JWT ----------
# 必须不少于 32 字节
MOUSECAKE_JWT_SECRET=dev-jwt-secret-must-be-at-least-32-bytes!!

# ---------- 管理员 ----------
# 必须不少于 8 位
MOUSECAKE_ADMIN_PASSWORD=dev_admin_123

# ---------- OKX 报价 API ----------
MOUSECAKE_QUOTE_OKX_API_KEY=
MOUSECAKE_QUOTE_OKX_SECRET_KEY=
MOUSECAKE_QUOTE_OKX_PASSPHRASE=

# ---------- Alchemy 节点 ----------
MOUSECAKE_ALCHEMY_API_KEY=

# ---------- 同步合约地址（Sepolia 测试网）----------
MOUSECAKE_SYNC_MOUSE_TIER_ADDRESS=
MOUSECAKE_SYNC_MOUSE_PAD_BY_TIER_ADDRESS=
